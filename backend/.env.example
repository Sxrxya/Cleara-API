# Environment Configuration
ENVIRONMENT=development
DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# AWS Configuration (Optional - for local development)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB Tables
DYNAMODB_USERS_TABLE=cleara-users-dev
DYNAMODB_API_KEYS_TABLE=cleara-api-keys-dev
DYNAMODB_USAGE_TABLE=cleara-usage-dev

# S3 Buckets
S3_MODELS_BUCKET=cleara-ml-models-dev
S3_LOGS_BUCKET=cleara-logs-dev

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ML Models
MODEL_CACHE_DIR=./models

# Monitoring
ENABLE_XRAY=False
LOG_LEVEL=INFO

# Stripe Configuration (Optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
